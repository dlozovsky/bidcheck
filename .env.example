# Required for analysis
OPENAI_API_KEY=

# Keep these defaults unless intentionally validating a model change
OPENAI_EXTRACTION_MODEL=gpt-5.6-sol
OPENAI_GAP_MODEL=gpt-5.6-sol
OPENAI_MEMO_MODEL=gpt-5.6-sol

# Use independent, high-entropy values in production
SAFETY_IDENTIFIER_SECRET=
RATE_LIMIT_HMAC_SECRET=

# Required in production for a direct Upstash setup. Vercel Marketplace
# installations inject KV_REST_API_URL and KV_REST_API_TOKEN instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=
RATE_LIMIT_PER_IP=5
RATE_LIMIT_GLOBAL=100

# Reserved stretch feature; there is no upload control while false
ENABLE_PDF_UPLOAD=false
